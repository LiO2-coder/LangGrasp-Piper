<?xml version="1.0" encoding="utf-8"?>
<mujoco model="piper_d435i_scene">
    <include file="piper_touch.xml"/>
    <size memory="128M"/>

    <statistic center="1.3 -0.7 0.5" extent="3.0"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20"/>
    </visual>

    <asset>      
        <mesh name="tetrahedron" vertex="0 0 0 1 0 0 0 1 0 0 0 1" scale="0.1 0.1 0.1"/>
        <texture type="skybox" file="assets/desert.png" gridsize="3 4" gridlayout=".U..LFRB.D.."/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1=".2 .3 .4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0"/>
        <material name="box" rgba="0 0.5 0 1" emission="0"/>
    </asset>

    <worldbody>
        <!-- 定向光源（Directional Light）类似太阳，光线平行 -->
        <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>

        <!-- 地面平面 -->
        <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>



        <body name="sphere_body" pos="0.45 0.00 0.01">
            <freejoint />
            <geom type="sphere" size="0.02" rgba=".5 0 0 1" />
        </body>

        <body name="box_body" pos="0.40 -0.06 0.01">
            <freejoint />
            <geom type="box" size="0.02 0.02 0.02" material="box" />
        </body>

        <body name="capsule_body" pos="0.52 -0.06 0.02">
            <freejoint />
            <geom type="capsule" size="0.02 0.01" rgba="0 0 .5 1" />
        </body>

        <body name="cylinder_body" pos="0.40 0.06 0.01">
            <freejoint />
            <geom type="cylinder" size="0.01 0.02" rgba=".5 .5 0 1" />
        </body>

        <body name="ellipsoid1_body" pos="0.45 0.10 0.01">
            <freejoint />
            <geom type="ellipsoid" size="0.02 0.02 0.01" rgba="0 .5 .5 1" />
        </body>

        <body name="ellipsoid2_body" pos="0.52 0.06 0.01">
            <freejoint />
            <geom type="ellipsoid" size="0.02 0.01 0.01" rgba=".5 0 .5 1" />
        </body>


    </worldbody>

</mujoco>
